{
  "name": "@nslookup-io/mcp-server",
  "version": "1.1.5",
  "mcpName": "io.github.venomseven/nslookup",
  "description": "MCP server for DNS lookups, propagation checks, and certificate monitoring via nslookup.io",
  "main": "dist/index.js",
  "bin": {
    "nslookup-mcp": "dist/index.js",
    "nslookup-mcp-http": "dist/http.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "start:http": "node dist/http.js",
    "dev": "tsc --watch",
    "prepublishOnly": "npm run build"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nslookup-io/nslookup-mcp.git"
  },
  "keywords": [
    "mcp",
    "dns",
    "nslookup",
    "propagation",
    "dns-lookup",
    "model-context-protocol",
    "claude",
    "ai-tools"
  ],
  "author": "nslookup.io",
  "license": "Apache-2.0",
  "bugs": {
    "url": "https://github.com/nslookup-io/nslookup-mcp/issues"
  },
  "homepage": "https://nslookup.io",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "express": "^5.1.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/express": "^5.0.2",
    "@types/node": "^25.5.0",
    "typescript": "^5.9.3"
  }
}
